# 默认 mock 模式，无需外部密钥即可跑通完整流程
MOCK_MODE=true
APP_HOST=0.0.0.0
APP_PORT=8001
PUBLIC_BASE_URL=http://127.0.0.1:8001
RUNTIME_DIR=runtime

# LLM / 火山方舟 / OpenAI-compatible
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-1-8-251228
ARK_TIMEOUT_SECONDS=120

# 业务系统回写接口，可替换为实际 yufabu.saizhuge.net 接口
BUSINESS_SYNC_API_URL=
BUSINESS_SYNC_TIMEOUT_SECONDS=30

# OBS / 对象存储
OBS_ACCESS_KEY=
OBS_SECRET_KEY=
OBS_SERVER=https://obs.cn-north-4.myhuaweicloud.com
OBS_BUCKET=yinglongzhiyou
OBS_PUBLIC_PREFIX=

# 讯飞 TTS，Demo 中未强依赖；真实接入时配置
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_TTS_URL=wss://tts-api.xfyun.cn/v2/tts
